# Environment Variables Required for Deployment

# Database connection string
# Example: Server=localhost;Database=MyDatabase;Integrated Security=true;
export ConnectionStrings__696fd374-e61c-4021-8970-36b6cb97591f="Data Source=localhost,1434;Initial Catalog=696fd374-e61c-4021-8970-36b6cb97591f;User Id=sa;Password=YourStrong!Passw0rd;Encrypt=false"

# Grate environment (affects which environment-specific scripts are run)
# Common values: LOCAL, DEV, STAGING, PRODUCTION
export GrateEnvironment=LOCAL

# Optional: Output directory for migration logs and backups
# If not specified, defaults to ./logs
# export OutDir=./logs

# Optional: Version to tag the migration with
# If not specified, will use GitVersion to generate a semantic version
# export Version=1.0.0

# Optional: Grate schema name (defaults to 'grate')
# export GrateSchemaName=grate

# Optional: Command timeout in seconds (defaults to 60)
# export CommandTimeout=60

# Optional: Administrator command timeout in seconds (defaults to 300)
# export AdminCommandTimeout=300

# Optional: Run migration in a transaction (defaults to false)
# export Transaction=false

# Optional: Dry run mode - logs what would run but doesn't execute (defaults to false)
# export DryRun=false


